{
  "name": "@wasp/core",
  "version": "0.1.0",
  "description": "WhatsApp Session Protocol - Unified session management and message routing for WhatsApp applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "whatsmeow",
    "session",
    "multi-tenant",
    "protocol",
    "messaging",
    "queue",
    "anti-ban"
  ],
  "author": "Kobus Wentzel <kobie3717@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kobie3717/wasp.git"
  },
  "bugs": {
    "url": "https://github.com/kobie3717/wasp/issues"
  },
  "homepage": "https://github.com/kobie3717/wasp#readme",
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitest/coverage-v8": "^1.3.1",
    "eslint": "^8.56.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "pino": "^8.19.0"
  },
  "peerDependencies": {
    "@whiskeysockets/baileys": "^6.0.0",
    "ioredis": "^5.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@whiskeysockets/baileys": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
